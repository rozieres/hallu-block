{
  "name": "hallu-block",
  "version": "1.0.0",
  "description": "Browser extension that hides the AI forced on you by default. A free tool by Hallu World.",
  "private": true,
  "license": "MIT",
  "homepage": "https://github.com/rozieres/hallu-block",
  "repository": {
    "type": "git",
    "url": "https://github.com/rozieres/hallu-block.git"
  },
  "scripts": {
    "lint": "node scripts/check.mjs",
    "lint:webext": "bash scripts/pack.sh lint chrome",
    "lint:firefox": "bash scripts/pack.sh lint firefox",
    "build": "bash scripts/pack.sh build chrome",
    "build:chrome": "bash scripts/pack.sh build chrome",
    "build:firefox": "bash scripts/pack.sh build firefox",
    "stage:chrome": "bash scripts/pack.sh stage chrome",
    "stage:firefox": "bash scripts/pack.sh stage firefox",
    "test": "playwright test",
    "test:canary": "playwright test --config=playwright.canary.config.js",
    "vendor:polyfill": "cp node_modules/webextension-polyfill/dist/browser-polyfill.min.js src/lib/browser-polyfill.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "web-ext": "^10.4.0",
    "webextension-polyfill": "0.12.0"
  }
}
