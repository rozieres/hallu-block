{
  "version": "2026.07.01",
  "hide": [
    {
      "id": "google-ai-overview",
      "hosts": ["google.com", "google.fr", "google.be", "google.ch", "google.ca"],
      "path": "/search",
      "selectors": [
        "div[data-async-type=\"folsrch\"]",
        "div[data-async-type=\"aiOverview\"]",
        "div[aria-label=\"AI Overview\"]",
        "div[data-attrid=\"AIOverview\"]"
      ],
      "textHeadings": ["AI Overview", "AI Overviews", "Aperçu IA", "Aperçus IA"],
      "ancestorSelectors": [
        "div[data-mcpr]",
        "div[data-async-type=\"folsrch\"]",
        "div[data-async-type=\"aiOverview\"]"
      ],
      "annotateKey": "annot_google_overview"
    },
    {
      "id": "bing-copilot",
      "hosts": ["bing.com"],
      "path": "/search",
      "selectors": [
        "#copans_container",
        "div.answer_container[aria-label=\"Copilot Search\"]",
        "div.answer_container[aria-label=\"Recherche Copilot\"]",
        "#b_copilot_search_container"
      ],
      "textHeadings": ["Copilot Search", "Recherche Copilot"],
      "ancestorSelectors": ["li.b_ans", "#b_copilot_search_container"],
      "annotateKey": "annot_generic",
      "annotMode": "css"
    },
    {
      "id": "youtube-ask",
      "hosts": ["youtube.com"],
      "selectors": [
        ".you-chat-entrypoint-button",
        "yt-video-description-youchat-section-view-model",
        ".ytp-suggested-action-badge[aria-label=\"Ask about this video\"]",
        "ytd-expandable-metadata-renderer[has-video-summary]"
      ],
      "ancestorSelectors": ["yt-button-view-model", "ytd-expandable-metadata-renderer"],
      "annotateKey": "annot_generic"
    },
    {
      "id": "amazon-rufus",
      "hosts": ["amazon.fr", "amazon.com"],
      "selectors": [
        "#nav-rufus-disco",
        "#nav-flyout-rufus",
        ".rufus-panel-container",
        ".rufus-view-filler",
        "#cr-product-insights-cards",
        "[data-csa-c-item-id=\"cr-product-insights-detail-page\"]"
      ],
      "ancestorSelectors": [],
      "annotateKey": "annot_generic"
    }
  ],
  "slopFilter": {
    "id": "anti-slop",
    "hosts": ["google.com", "google.fr", "google.be", "google.ch", "google.ca", "bing.com", "duckduckgo.com"],
    "resultSelector": "#rso div.g, #b_results > li.b_algo, article[data-testid=\"result\"]",
    "annotateKey": "annot_slop",
    "listName": "uBlockOrigin-AI-Blocklist",
    "listUrl": "https://codeberg.org/just_a_husk/uBlockOrigin-AI-Blocklist"
  }
}
